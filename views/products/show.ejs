<% layout("./layouts/boilerplate") -%>

<div class="container mt-5">

    <!-- PRODUCT SECTION -->
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h3 class="mb-3"><%= product.title %></h3>

            <div class="card shadow-sm border-0">

                <img src="<%=product.image.url%>" class="card-img-top show-img" alt="product-image">

                <div class="card-body">
                    <p class="text-muted mb-1"><i>By <%= product.owner.username %></i></p>

                    <p class="card-text">
                        <%= product.description %>
                    </p>

                    <h5 class="fw-bold">
                        ₹<%= product.price ? product.price.toLocaleString("en-IN") : "N/A" %>
                    </h5>
                </div>

                <!-- BUTTONS -->
                <% if(currUser && currUser._id.equals(product.owner._id)){ %>
                    <div class="card-body d-flex gap-2">
                        <a href="/products/<%=product._id%>/edit" class="btn btn-secondary">
                            Edit
                        </a>
    
                        <form method="post" action="/products/<%=product._id%>?_method=DELETE">
                            <button class="btn btn-danger">
                                Delete
                            </button>
                        </form>
                    </div>
                 <% } %>

            </div>
        </div>
    </div>


    <hr class="my-5">


    <!-- REVIEW FORM -->
    <div class="row justify-content-center">
        <div class="col-md-6">

            <h4 class="mb-3">Leave a Review</h4>

            <% if(currUser){ %>
                <form method="POST"
                    action="/products/<%=product._id%>/review"
                    novalidate
                    class="needs-validation">
    
                    <div class="mb-3">
                        <label for="rating" class="form-label">Rating</label>
    
                        <fieldset class="starability-checkmark">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>

                    </div>
    
                    <div class="mb-3">
                        <label for="comment" class="form-label">
                            Experience with the product
                        </label>
    
                        <textarea
                            name="review[comment]"
                            id="comment"
                            rows="4"
                            class="form-control"
                            required></textarea>
    
                        <div class="invalid-feedback">
                            Comment cannot be empty
                        </div>
                    </div>
    
                    <button class="btn btn-secondary">
                        Submit Review
                    </button>
    
                </form>
            <% }else{ %>
                <div class="row justify-content-center mt-5">
                    <div class="col-md-6">

                        <div class="card text-center shadow-sm border-0 p-4">

                            <h5 class="mb-3 text-muted">
                                You must be logged in to leave a review
                            </h5>

                            <a href="/login" class="btn btn-dark">
                                Login to Continue
                            </a>

                        </div>

                    </div>
                </div>
            <% } %>

        </div>
    </div>


    <hr class="my-5">


    <!-- REVIEWS -->
    <div class="row justify-content-center">
        <div class="col-md-8">

            <h4 class="mb-4">All Reviews</h4>

            <div class="row">

                <% for(review of product.reviews) { %>

                    <div class="col-md-6 mb-3">

                        <div class="card shadow-sm h-100">

                            <div class="card-body">

                                <h6 class="card-title fw-bold">
                                    <%= review.author.username%>
                                </h6>

                                <p class="card-text">
                                    <%= review.comment %>
                                </p>

                                <p class="card-text text-warning">
                                    <%= review.rating %> ★
                                </p>

                                <p class="card-text starability-result" data-rating="<%= review.rating %>"></p>

                                <p class="text-muted small">
                                    Was this review helpful?
                                </p>
                                
                                <% if(currUser && currUser._id.equals(review.author._id)){ %>
                                <form method="post"
                                    action="/products/<%=product._id%>/review/<%=review._id%>?_method=DELETE">

                                    <button class="btn btn-sm btn-danger">
                                        Delete
                                    </button>
                                <% } %>
                                </form>

                            </div>

                        </div>

                    </div>

                <% } %>

            </div>

        </div>
    </div>

</div>